{
  "metadata": {
    "name": "Oracle Sandbox",
    "product": "Oracle Sandbox",
    "version": "1.0.1",
    "purpose": "Oracle AI Database 26ai Free — fully containerized developer environment for PL/SQL development, APEX building, DBA training, prototyping, workshops, and Oracle feature exploration",
    "description": "Comprehensive knowledge base and instructions for Oracle Sandbox AI operations",
    "repository": "demasy/oracle-sandbox",
    "organization": "Demasy Labs",
    "owner": "Demasy Labs",
    "owner_email": "founder@demasy.io",
    "owner_github": "https://github.com/demasy",
    "license": "MIT",
    "homepage": "https://github.com/demasy/oracle-sandbox#readme",
    "issues": "https://github.com/demasy/oracle-sandbox/issues",
    "copyright": "Copyright © 2026 Demasy Labs. Licensed under the MIT License.",
    "created": "2026-01-19",
    "last_updated": "2026-03-10"
  },
  "rules": {
    "critical": [
      {
        "rule": "CODACY_ANALYSIS_AFTER_EDITS",
        "description": "MUST run codacy_cli_analyze immediately after ANY successful file edit",
        "parameters": {
          "rootPath": "workspace path",
          "file": "edited file path",
          "tool": "empty or unset"
        }
      },
      {
        "rule": "SECURITY_CHECK_AFTER_DEPENDENCIES",
        "description": "MUST run codacy_cli_analyze with tool='trivy' after installing ANY dependencies",
        "triggers": [
          "npm install",
          "yarn add",
          "pnpm install",
          "requirements.txt changes",
          "package.json changes"
        ]
      }
    ],
    "normal": [
      {
        "rule": "ALWAYS_CHECK_BRAIN_FIRST",
        "description": "Before taking ANY action, consult this brain.json file for instructions, conventions, and guidelines"
      },
      {
        "rule": "ENVIRONMENT_VARIABLE_NAMING",
        "description": "Use ENV_* prefix for host-level (.env, docker-compose.yml). Use SANDBOX_* prefix for container-level (scripts running inside containers)",
        "examples": {
          "host_level": [
            "ENV_DB_PASSWORD",
            "ENV_APEX_PORT",
            "ENV_NETWORK_SUBNET"
          ],
          "container_level": [
            "SANDBOX_DB_HOST",
            "SANDBOX_APEX_EMAIL",
            "SANDBOX_DB_SERVICE"
          ]
        }
      },
      {
        "rule": "NO_EXPERIMENTAL_SCRIPTS",
        "description": "NEVER use or modify scripts in src/scripts/experimental/ directory"
      }
    ]
  },
  "architecture": {
    "type": "Containerized Oracle Development Environment",
    "purpose": "Development, training, and exploration only - NOT production",
    "containers": {
      "database": {
        "name": "demasylabs-oracle-database",
        "image": "container-registry.oracle.com/database/free:latest",
        "version": "Oracle AI Database 26ai Free",
        "static_ip": "192.168.1.110",
        "ports": {
          "1521": "Oracle Listener",
          "5500": "Enterprise Manager Express",
          "9090": "Additional services"
        }
      },
      "management_server": {
        "name": "demasylabs-oracle-server",
        "image": "demasylabs-oracle-sandbox:latest",
        "base": "Node.js 20.19.4 LTS",
        "static_ip": "192.168.1.120",
        "ports": {
          "3000": "Management API",
          "3001": "MCP Server",
          "8080": "ORDS/APEX Web Interface"
        },
        "includes": [
          "SQLcl 25.2.2",
          "Oracle Instant Client 23.7",
          "APEX 24.2.0",
          "ORDS 26.1"
        ]
      }
    },
    "network": {
      "name": "demasylabs_network",
      "driver": "bridge",
      "subnet": "192.168.1.0/24",
      "gateway": "192.168.1.1",
      "note": "Container IPs are only accessible within Docker network, use port forwarding from host"
    },
    "platform_support": {
      "platforms": ["AMD64 (x86_64)", "ARM64 (Apple Silicon/aarch64)"],
      "sqlcl": "Works on all architectures",
      "sqlplus": "AMD64 only - ARM64 falls back to SQLcl",
      "java": "Dynamically detected: /usr/lib/jvm/java-17-openjdk-*",
      "oracle_instant_client": {
        "versions": ["19.26", "21.17", "23.7"],
        "current": "23.7",
        "auto_download": "Downloads architecture-specific version if not present locally"
      }
    },
    "ports": {
      "1521": "Oracle Listener",
      "3000": "Management API",
      "3001": "MCP Server",
      "5500": "Enterprise Manager Express",
      "8080": "ORDS/APEX Web Interface",
      "9090": "Additional Oracle services"
    },
    "external_access": {
      "note": "Database is accessible from outside via port forwarding",
      "connection_methods": {
        "port_forwarding": {
          "status": "Already working",
          "database": "localhost:1521 → 192.168.1.110:1521",
          "apex": "localhost:8080 → 192.168.1.120:8080",
          "em_express": "localhost:5500 → 192.168.1.110:5500"
        },
        "direct_ip_access": {
          "status": "Not available on macOS Docker Desktop",
          "reason": "Docker bridge networks don't expose to host",
          "workaround": "Use port forwarding or host network mode"
        }
      }
    },
    "constraints": {
      "deployment": "Development only - NOT production-ready",
      "architecture": "Must support both AMD64 and ARM64",
      "configuration": "All config via environment variables",
      "operations": "All operations happen inside containers",
      "persistence": "Database data in Docker volumes (demasylabs_oracle_vol)"
    }
  },
  "structure": {
    "scripts": {
      "path": "src/scripts/",
      "organization": "flat, context-based hierarchy (max 3 levels)",
      "subdirectories": {
        "backbone/utils": {
          "purpose": "Shared utilities following DRY principle — sourced by all other scripts",
          "container_path": "/usr/demasy/scripts/backbone/utils/",
          "files": [
            "colors.sh",
            "logging.sh",
            "banner.sh",
            "commands.sh",
            "detect-arch.sh",
            "download-file.sh",
            "apex-completion.sh"
          ],
          "usage": "source \"$SCRIPT_DIR/../../backbone/utils/logging.sh\""
        },
        "backbone/build": {
          "purpose": "Container startup and build-time initialization",
          "container_path": "/usr/demasy/scripts/build/",
          "files": [
            "builder-startup.sh",
            "startup.sh"
          ],
          "note": "CMD in Dockerfile points to startup.sh"
        },
        "cli": {
          "purpose": "User-facing database connection shortcuts",
          "container_path": "/usr/demasy/scripts/cli/",
          "files": [
            "commands.sh",
            "sqlcl-connect.sh",
            "sqlplus-connect.sh"
          ],
          "symlinks": {
            "sqlcl": "sqlcl-connect.sh",
            "sqlplus": "sqlplus-connect.sh",
            "oracle": "sqlcl-connect.sh",
            "commands": "commands.sh"
          }
        },
        "oracle/admin": {
          "purpose": "DBA and user administration, privilege management, installation, database links",
          "container_path": "/usr/demasy/scripts/oracle/admin/",
          "files": [
            "healthcheck.sh",
            "create_user.sh",
            "create-demasy-user.sh",
            "rollback-demasy-user.sh",
            "grant-privileges.sh",
            "create-db-link.sh",
            "download.sh",
            "download-apex.sh",
            "download-apex-standalone.sh",
            "download-ords.sh",
            "install-all.sh",
            "install-client.sh",
            "install-sqlcl.sh",
            "install-sqlplus.sh"
          ]
        },
        "oracle/apex": {
          "purpose": "APEX/ORDS lifecycle management",
          "container_path": "/usr/demasy/scripts/oracle/apex/",
          "files": [
            "install.sh",
            "start.sh",
            "stop.sh",
            "uninstall.sh"
          ],
          "note": "install.sh handles complete APEX+ORDS setup"
        },
        "oracle/mcp": {
          "purpose": "Model Context Protocol server",
          "status": "stable"
        },
        "docker": {
          "purpose": "Container operations — hot deploy and Docker Hub publishing",
          "files": [
            "deploy-scripts.sh",
            "publish-images.sh"
          ]
        },
        "security": {
          "purpose": "Security and vulnerability scanning",
          "files": [
            "vulnerability-scan.sh"
          ]
        },
        "experimental": {
          "purpose": "Archived / unstable scripts",
          "rule": "DO NOT USE OR MODIFY",
          "enforcement": "strict"
        }
      }
    },
    "docs": {
      "path": "src/docs/",
      "files": [
        "README.md",
        "configuration-reference.md",
        "database-connectivity.md",
        "external-database-access.md",
        "monitoring.md",
        "oracle-apex-installation.md",
        "service-management.md",
        "startup-configuration.md",
        "troubleshooting.md",
        "SECURITY.md",
        "SECURITY-AUDIT.md"
      ]
    },
    "libraries": {
      "path": "libs/oracle/",
      "subdirectories": {
        "apex": "APEX installation files",
        "clients": {
          "instantclient_19_26": "Oracle 19c compatibility",
          "instantclient_21_17": "Oracle 21c",
          "instantclient_23_7": "Current version (used in Dockerfile)"
        }
      },
      "note": "Auto-downloaded if not present locally (architecture-specific)"
    }
  },
  "golden-standard": {
    "scripts": {
      "actions": {
        "pattern": "verb-noun.sh",
        "examples": [
          "install-apex.sh",
          "start-ords.sh",
          "check-health.sh"
        ]
      },
      "utilities": {
        "pattern": "noun.sh",
        "examples": [
          "colors.sh",
          "logging.sh",
          "banner.sh"
        ]
      },
      "rule": "No redundant prefixes - context comes from directory"
    },
    "directories": {
      "case": "lowercase",
      "separator": "hyphen for multi-word",
      "nesting": "max 3 levels",
      "examples": [
        "oracle-admin",
        "apex-config"
      ]
    },
    "environment_variables": {
      "host_level": "ENV_*",
      "container_level": "SANDBOX_*",
      "mapping": "ENV_* → SANDBOX_* in docker-compose.yml"
    },
    "logging": {
      "utility_file": "src/scripts/backbone/utils/logging.sh",
      "functions": {
        "log_info": "Informational messages",
        "log_success": "Success/completion messages",
        "log_error": "Error messages",
        "log_warn": "Warning messages",
        "log_step": "Process steps"
      },
      "usage": "Always source logging.sh in scripts"
    },
    "security": {
      "never_commit": [".env", "*.pem", "*.key", "secrets.json", "config.local.js"],
      "password_requirements": "Mixed case, numbers, symbols",
      "default_workspace": "INTERNAL (always exists in APEX)",
      "admin_credentials": {
        "username_from": "ENV_APEX_ADMIN_USERNAME",
        "password_from": "ENV_APEX_ADMIN_PASSWORD"
      }
    }
  },
  "workflows": {
    "building_services": {
      "clean_build": "docker-compose build --no-cache",
      "start": "docker-compose up -d",
      "check_status": "docker ps",
      "view_logs": "docker logs -f demasylabs-oracle-database",
      "success_message": "DATABASE IS READY TO USE!",
      "note": "Always use --no-cache for Oracle client changes"
    },
    "accessing_containers": {
      "management_server": "docker exec -it demasylabs-oracle-server bash",
      "database": "docker exec -it demasylabs-oracle-database bash"
    },
    "database_connection": {
      "from_container": [
        "docker exec -it demasylabs-oracle-server sqlcl",
        "docker exec -it demasylabs-oracle-server sqlplus",
        "docker exec -it demasylabs-oracle-server oracle"
      ],
      "from_host": [
        "sqlplus system/password@localhost:1521/FREEPDB1",
        "sql system/password@localhost:1521/FREEPDB1"
      ],
      "note": "CLI commands are bash scripts in src/scripts/cli/ that auto-load environment variables"
    },
    "apex_management": {
      "install": "docker exec -it demasylabs-oracle-server install-apex",
      "start": "docker exec -it demasylabs-oracle-server start-apex",
      "stop": "docker exec -it demasylabs-oracle-server stop-apex",
      "access_url": "http://localhost:8080/ords/f?p=4550:1",
      "install_time": "3-5 minutes",
      "note": "APEX must be installed manually after database starts"
    },
    "adding_new_script": {
      "steps": [
        "1. Create in src/scripts/{category}/your-script.sh",
        "2. Source backbone utilities (use relative path via SCRIPT_DIR)",
        "3. Use SANDBOX_* environment variables (NOT ENV_*)",
        "4. Hot-deploy using deploy-scripts.sh (no Dockerfile rebuild needed)",
        "5. Add to get_symlink_name() in deploy-scripts.sh if user-facing",
        "6. Update src/scripts/README.md"
      ],
      "template": "#!/bin/bash\nSCRIPT_PATH=\"$(readlink -f \"${BASH_SOURCE[0]}\")\"\nSCRIPT_DIR=\"$(dirname \"$SCRIPT_PATH\")\"\nsource \"$SCRIPT_DIR/../../backbone/utils/banner.sh\"\nsource \"$SCRIPT_DIR/../../backbone/utils/logging.sh\"\nsource \"$SCRIPT_DIR/../../backbone/utils/colors.sh\"",
      "deploy_command": "./src/scripts/docker/deploy-scripts.sh"
    },
    "admin_scripts": {
      "description": "Admin scripts deployed to /usr/demasy/scripts/oracle/admin/ and symlinked in /usr/local/bin/",
      "scripts": {
        "create_user": {
          "path": "src/scripts/oracle/admin/create_user.sh",
          "signature": "create_user.sh <username> [password] [pdb_name]",
          "description": "Creates a PDB user with Oracle 26ai privileges including assertion, vector, graph, JSON, and spatial grants",
          "symlink": "create-user"
        },
        "create-demasy-user": {
          "path": "src/scripts/oracle/admin/create-demasy-user.sh",
          "signature": "create-demasy-user",
          "description": "Creates SANDBOX_PDB pluggable database, demasy user, and c##demasy common user — full 841-line provisioning script",
          "symlink": "create-demasy-user"
        },
        "rollback-demasy-user": {
          "path": "src/scripts/oracle/admin/rollback-demasy-user.sh",
          "signature": "rollback-demasy-user",
          "description": "Full rollback of SANDBOX_PDB, demasy user, and c##demasy — 1154-line undo script",
          "symlink": "rollback-demasy-user"
        },
        "grant-privileges": {
          "path": "src/scripts/oracle/admin/grant-privileges.sh",
          "signature": "grant-privileges.sh <username> [level] [pdb_name]",
          "description": "Grants privileges to an existing user at a chosen cumulative level",
          "symlink": "grant-privileges",
          "levels": {
            "minimal": "CONNECT, RESOURCE, UNLIMITED TABLESPACE, basic CREATE privileges",
            "normal": "Minimal + SELECT_CATALOG_ROLE, all CREATE/ALTER/DROP ANY, Oracle 26ai features (default)",
            "all": "Normal + DBA role, tablespace admin, role/profile/user management, GRANT ANY PRIVILEGE"
          }
        },
        "create-db-link": {
          "path": "src/scripts/oracle/admin/create-db-link.sh",
          "signature": "create-db-link.sh <link_name> <owner_user> <owner_password> <remote_user> <remote_password> <remote_host> <remote_port> <remote_service> [pdb_name]",
          "description": "Creates a private database link owned by a specific local PDB user — idempotent DROP+CREATE with live connectivity test",
          "symlink": "create-db-link",
          "steps": [
            "1. Test CDB connection (3 retries)",
            "2. Verify PDB is open READ WRITE, auto-open if MOUNTED",
            "3. Verify owner user exists in PDB",
            "4. Drop existing link if present (idempotency)",
            "5. CREATE DATABASE LINK using owner credentials",
            "6. Test link with SELECT DUAL@link_name"
          ]
        },
        "healthcheck": {
          "path": "src/scripts/oracle/admin/healthcheck.sh",
          "signature": "healthcheck",
          "description": "Database connectivity and service health verification",
          "symlink": "healthcheck"
        },
        "install-all": {
          "path": "src/scripts/oracle/admin/install-all.sh",
          "description": "Installs all Oracle components (Instant Client + SQLcl + SQLPlus)",
          "symlink": "install-all"
        },
        "download": {
          "path": "src/scripts/oracle/admin/download.sh",
          "description": "Downloads Oracle Instant Client components (architecture-specific)",
          "symlink": "download-oracle-components"
        },
        "download-apex": {
          "path": "src/scripts/oracle/admin/download-apex.sh",
          "description": "Downloads APEX and ORDS installation archives",
          "symlink": "download-apex"
        }
      },
      "deploy": "./src/scripts/docker/deploy-scripts.sh",
      "single_file": "./src/scripts/docker/deploy-scripts.sh --file create_user.sh --symlink"
    },
    "testing": {
      "health_endpoints": {
        "management_api": "curl http://localhost:3000/health",
        "apex_builder": "curl http://localhost:8080/ords/f?p=4550:1",
        "apex_images": "curl http://localhost:8080/i/apex_ui/css/Core.css"
      },
      "database_checks": {
        "apex_installation": "SELECT comp_name, version, status FROM dba_registry WHERE comp_id='APEX';",
        "ords_schemas": "SELECT username, account_status FROM dba_users WHERE username LIKE 'ORDS%';",
        "apex_admin": "SELECT user_name, is_admin, account_locked FROM apex_workspace_apex_users WHERE workspace_name = 'INTERNAL';"
      }
    },
    "debugging": {
      "container_health": "docker inspect demasy-server --format='{{.State.Health.Status}}'",
      "view_logs": "docker logs demasy-server --tail 100",
      "test_connectivity": "docker exec demasylabs-oracle-server ping 192.168.1.110",
      "check_ords": "docker exec demasylabs-oracle-server netstat -tulnp | grep :8080",
      "apex_images_issue": "Check /tmp/i/ has ~855 files, restart ORDS"
    }
  },
  "critical_files": {
    ".env": {
      "purpose": "Environment configuration — never committed to git",
      "never_commit": true,
      "variables_prefix": "ENV_*",
      "critical_vars": [
        "ENV_DB_PASSWORD",
        "ENV_DB_SID",
        "ENV_DB_SERVICE",
        "ENV_DB_USER",
        "ENV_DB_PORT_LISTENER",
        "ENV_DB_PORT_EM",
        "ENV_DB_CHARACTERSET",
        "ENV_DB_CLIENT",
        "ENV_DB_MCP_USER",
        "ENV_DB_POOL_MIN",
        "ENV_DB_POOL_MAX",
        "ENV_DB_POOL_INCREMENT",
        "ENV_DB_CPU_LIMIT",
        "ENV_DB_MEMORY_LIMIT",
        "ENV_NETWORK_SUBNET",
        "ENV_NETWORK_GATEWAY",
        "ENV_IP_DB_SERVER",
        "ENV_IP_APP_SERVER",
        "ENV_SERVER_PORT",
        "ENV_SERVER_CPU_LIMIT",
        "ENV_SERVER_MEMORY_LIMIT",
        "ENV_APEX_PORT",
        "ENV_MCP_PORT",
        "ENV_APEX_ADMIN_USERNAME",
        "ENV_APEX_ADMIN_PASSWORD",
        "ENV_APEX_EMAIL",
        "ENV_APEX_DEFAULT_WORKSPACE",
        "ENV_AUTO_INSTALL_APEX_ON_STARTUP",
        "ENV_SHOW_APEX_INSTALL_LOGS",
        "ENV_APEX_INSTALL_TIMEOUT",
        "ENV_STARTUP_WAIT_FOR_DB",
        "ENV_STARTUP_DB_WAIT_TIMEOUT",
        "ENV_STARTUP_DB_WAIT_INTERVAL",
        "ENV_INSTALL_APEX",
        "ENV_TIME_ZONE",
        "ENV_NODE_ENV",
        "ENV_SRC_ORACLE_SQLCL",
        "ENV_SRC_ORACLE_SQLPLUS",
        "ENV_SRC_ORACLE_APEX",
        "ENV_SRC_ORACLE_ORDS",
        "ENV_SRC_ORACLE_INSTANTCLIENT"
      ]
    },
    "docker-compose.yml": {
      "purpose": "Container orchestration — maps ENV_* → SANDBOX_* for container environment",
      "volumes": [
        "demasylabs_oracle_vol — Oracle data persistence",
        "demasylabs_logs_vol — Application log persistence (mounted at /home/oracle/logs)"
      ]
    },
    "Dockerfile": {
      "purpose": "Two-stage build: demasylabs-builder (Node slim + scripts) → runtime (Node slim + Java 17 + Oracle tools)",
      "script_paths": {
        "backbone/utils": "/usr/demasy/scripts/backbone/utils/",
        "cli": "/usr/demasy/scripts/cli/",
        "oracle/admin": "/usr/demasy/scripts/oracle/admin/",
        "oracle/apex": "/usr/demasy/scripts/oracle/apex/",
        "oracle/mcp": "/usr/demasy/scripts/oracle/mcp/",
        "backbone/build": "/usr/demasy/scripts/build/"
      },
      "symlinks": {
        "sql": "custom wrapper with dynamic Java detection",
        "download-oracle-components": "download.sh",
        "commands": "cli/commands.sh",
        "sqlplus": "cli/sqlplus-connect.sh",
        "sqlcl": "cli/sqlcl-connect.sh",
        "oracle": "cli/sqlcl-connect.sh",
        "download-apex": "oracle/admin/download-apex.sh",
        "install-apex": "oracle/apex/install.sh",
        "uninstall-apex": "oracle/apex/uninstall.sh",
        "start-apex": "oracle/apex/start.sh",
        "stop-apex": "oracle/apex/stop.sh",
        "install-all": "oracle/admin/install-all.sh",
        "install-client": "oracle/admin/install-client.sh",
        "install-sqlplus": "oracle/admin/install-sqlplus.sh",
        "install-sqlcl": "oracle/admin/install-sqlcl.sh",
        "healthcheck": "oracle/admin/healthcheck.sh",
        "create-demasy-user": "oracle/admin/create-demasy-user.sh",
        "rollback-demasy-user": "oracle/admin/rollback-demasy-user.sh"
      },
      "note": "deploy-scripts.sh hot-deploys scripts without rebuild; its get_symlink_name() mirrors the Dockerfile symlink map"
    }
  },
  "version_information": {
    "oracle_db": {
      "version": "26ai Free",
      "release": "23.26.1.0.0",
      "status": "current"
    },
    "apex": {
      "version": "24.2.0",
      "status": "latest"
    },
    "ords": {
      "version": "25.3.1",
      "status": "latest"
    },
    "sqlcl": {
      "version": "25.2",
      "status": "latest"
    },
    "nodejs": {
      "version": "20.19.4 LTS",
      "status": "stable"
    },
    "instant_client": {
      "version": "23.7",
      "status": "current"
    }
  },
  "common_issues": {
    "apex_images_not_loading": {
      "solution": "Check /tmp/i/ has ~855 files, restart ORDS",
      "commands": [
        "docker exec demasylabs-oracle-server ls -la /tmp/i/ | wc -l",
        "docker exec demasylabs-oracle-server stop-apex",
        "docker exec demasylabs-oracle-server start-apex"
      ]
    },
    "container_ip_not_pingable": {
      "issue": "Normal behavior - Docker bridge networks don't expose internal IPs to host",
      "solution": "Use port forwarding (localhost:1521, localhost:8080, etc.)",
      "note": "Internal container-to-container communication works perfectly"
    },
    "database_not_starting": {
      "check": "docker logs demasylabs-oracle-database",
      "wait_for": "DATABASE IS READY TO USE!",
      "typical_time": "2-5 minutes"
    }
  },
  "codacy_integration": {
    "after_file_edit": {
      "action": "Run codacy_cli_analyze",
      "parameters": { "rootPath": "workspace path", "file": "edited file path", "tool": "" }
    },
    "after_dependencies": {
      "action": "Run codacy_cli_analyze with trivy",
      "parameters": { "rootPath": "workspace path", "tool": "trivy", "file": "" }
    },
    "cli_not_installed": {
      "response": "Ask user if they want to install",
      "yes": "Run codacy_cli_install tool",
      "no": "Instruct about extension settings"
    },
    "404_error": {
      "response": "Offer codacy_setup_repository",
      "user_acceptance_required": true
    }
  },
  "external_access": {
    "note": "Database is accessible from outside via port forwarding",
    "connection_methods": {
      "port_forwarding": {
        "status": "Already working",
        "database": "localhost:1521 → 192.168.1.110:1521",
        "apex": "localhost:8080 → 192.168.1.120:8080",
        "em_express": "localhost:5500 → 192.168.1.110:5500"
      },
