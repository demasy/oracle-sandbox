#==============================================================================
# DEMASYLABS Oracle Sandbox - Developer Environment Configuration
#==============================================================================

#------------------------------------------------------------------------------
# REGIONAL SETTINGS
#------------------------------------------------------------------------------
ENV_TIME_ZONE=Asia/Riyadh

#------------------------------------------------------------------------------
# APPLICATION CONFIGURATION
#------------------------------------------------------------------------------
ENV_NODE_ENV=demasylabs

#------------------------------------------------------------------------------
# NETWORK CONFIGURATION
#------------------------------------------------------------------------------
ENV_NETWORK_SUBNET=192.168.1.0/24
ENV_NETWORK_GATEWAY=192.168.1.1
ENV_IP_DB_SERVER=192.168.1.110
ENV_IP_APP_SERVER=192.168.1.120

#------------------------------------------------------------------------------
# PORT CONFIGURATION
#------------------------------------------------------------------------------
ENV_DB_PORT_LISTENER=1521
ENV_DB_PORT_EM=5500
ENV_SERVER_PORT=3000

#------------------------------------------------------------------------------
# ORACLE DATABASE CONFIGURATION
#------------------------------------------------------------------------------
ENV_DB_CLIENT=/opt/oracle/instantclient
ENV_DB_SID=FREE
ENV_DB_SERVICE=FREEPDB1
ENV_DB_NAME=FREE
ENV_DB_CHARACTERSET=AL32UTF8
ENV_DB_USER=system
ENV_DB_ADMIN_USER=system
ENV_DB_MCP_USER=sandbox_ai
ENV_DB_MCP_SERVICE=SANDBOX_PDB
ENV_DB_DEFAULT_PASSWORD=CHANGE_ME_SECURE_PASSWORD
ENV_DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
ENV_DB_POOL_MIN=1
ENV_DB_POOL_MAX=5
ENV_DB_POOL_INCREMENT=1

#------------------------------------------------------------------------------
# ORACLE APEX CONFIGURATION
#------------------------------------------------------------------------------
ENV_APEX_HOME=/opt/oracle/apex
ENV_APEX_IMAGES_DIR=/tmp/i
ENV_APEX_INSTALL_LOG=/tmp/apex_install.log
ENV_APEX_TABLE_SPACE=SANDBOX_APEX_TS
ENV_APEX_TABLE_SPACE_FILES=SANDBOX_APEX_FILES_TS
ENV_APEX_DEFAULT_WORKSPACE=SANDBOX
ENV_APEX_ADMIN_USERNAME=ADMIN
ENV_APEX_ADMIN_PASSWORD=CHANGE_ME_SECURE_PASSWORD
ENV_APEX_ADMIN_EMAIL=your.email@example.com
ENV_APEX_EMAIL=your.email@example.com
ENV_APEX_SECURITY_GROUP_ID=10
ENV_APEX_TABLESPACE_SIZE=500M
ENV_APEX_TABLESPACE_AUTOEXTEND=100M
ENV_APEX_PORT=8080

#------------------------------------------------------------------------------
# ORACLE ORDS CONFIGURATION
#------------------------------------------------------------------------------
ENV_ORDS_HOME=/opt/oracle/ords
ENV_ORDS_CONFIG=/opt/oracle/ords/config
ENV_ORDS_LOG=/tmp/ords.log
ENV_ORDS_PORT=8080
ENV_ORDS_JDBC_MIN_LIMIT=3
ENV_ORDS_JDBC_MAX_LIMIT=20
ENV_ORDS_JDBC_INITIAL_LIMIT=3
ENV_ORDS_STATEMENT_TIMEOUT=900

#------------------------------------------------------------------------------
# MODEL CONTEXT PROTOCOL (MCP) CONFIGURATION
#------------------------------------------------------------------------------
ENV_MCP_ENABLED=true
ENV_MCP_PORT=3001

#------------------------------------------------------------------------------
# RESOURCE LIMITS - DATABASE CONTAINER
#------------------------------------------------------------------------------
ENV_DB_CPU_LIMIT=2
ENV_DB_MEMORY_LIMIT=4g

#------------------------------------------------------------------------------
# RESOURCE LIMITS - APPLICATION CONTAINER
#------------------------------------------------------------------------------
ENV_SERVER_CPU_LIMIT=3.0
ENV_SERVER_MEMORY_LIMIT=3g

#------------------------------------------------------------------------------
# ORACLE CLIENT DOWNLOAD SOURCES (BUILD ARGUMENTS)
#------------------------------------------------------------------------------
ENV_SRC_OFFLINE_MODE=false
ENV_SRC_OFFLINE_PATH=./libs/oracle
ENV_SRC_OFFLINE_SQLCL=SQLcl/sqlcl-latest.zip
ENV_SRC_OFFLINE_SQLPLUS=instantclient-sqlplus-linux.arm64-23.9
ENV_SRC_OFFLINE_APEX=apex-latest.zip
ENV_SRC_OFFLINE_ORDS=ords-latest.zip
ENV_SRC_OFFLINE_POS_SCHEMA=v1.0.zip
ENV_SRC_ORACLE_OFFLINE=false
ENV_SRC_ORACLE_SQLCL=https://download.oracle.com/otn_software/java/sqldeveloper/sqlcl-25.2.2.199.0918.zip
ENV_SRC_ORACLE_SQLPLUS=https://download.oracle.com/otn_software/linux/instantclient/2390000/instantclient-sqlplus-linux.arm64-23.9.0.25.07.zip
ENV_SRC_ORACLE_APEX=https://download.oracle.com/otn_software/apex/apex-latest.zip
ENV_SRC_ORACLE_ORDS=https://download.oracle.com/otn_software/java/ords/ords-latest.zip
ENV_SRC_POS_SCHEMA=https://github.com/demasylabs/Point-Of-Sale/archive/refs/tags/v1.0.zip
ENV_SRC_ORACLE_INSTANTCLIENT=https://download.oracle.com/otn_software/linux/instantclient/2390000/instantclient-basic-linux.x64-23.9.0.25.07.zip

#------------------------------------------------------------------------------
# STARTUP BEHAVIOR CONFIGURATION
#------------------------------------------------------------------------------
ENV_INSTALL_APEX=true
ENV_AUTO_INSTALL_APEX_ON_STARTUP=true
ENV_SHOW_APEX_INSTALL_LOGS=true
ENV_APEX_INSTALL_TIMEOUT=600
ENV_STARTUP_WAIT_FOR_DB=true
ENV_STARTUP_DB_WAIT_TIMEOUT=120
ENV_STARTUP_DB_WAIT_INTERVAL=5
